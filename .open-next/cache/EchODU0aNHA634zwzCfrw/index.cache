{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"th\" class=\"inter_9e32615b-module__tlusTq__className\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/83afe278b6a6bb3c-s.p.2bn3s6zvc0dyp.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/2ezncouz1i_2q.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/1_akdfhhqaauv.js\"/><script src=\"/_next/static/chunks/0atut6a2uuyid.js\" async=\"\"></script><script src=\"/_next/static/chunks/3rxl-jt3pdxgx.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-40v4ysvnlnx8d.js\" async=\"\"></script><script src=\"/_next/static/chunks/158myu8e_yme3.js\" async=\"\"></script><script src=\"/_next/static/chunks/1c5awo7kppu7r.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>AI SNAP – The Ultimate AI Photobooth Platform</title><meta name=\"description\" content=\"Transform your events with world-class AI imaging. Instantly generate stunning, premium avatars for your guests.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body style=\"margin:0;padding:0;background:#fafafa;color:#0a0a0a\"><div hidden=\"\"><!--$--><!--/$--></div><div style=\"min-height:100vh;display:flex;flex-direction:column;font-family:Inter, sans-serif;background:#fafafa\"><header style=\"width:100%;padding:20px 40px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(0,0,0,0.08);background:rgba(255,255,255,0.85);backdrop-filter:blur(12px);position:sticky;top:0;z-index:100;box-sizing:border-box\"><div style=\"font-weight:800;font-size:22px;letter-spacing:-0.04em;color:#0a0a0a\">AI<span style=\"color:#D4AF37\">SNAP</span></div><nav style=\"display:flex;gap:32px;font-size:14px;font-weight:500;color:#555\"><a href=\"#features\" style=\"color:#555;text-decoration:none;transition:color 0.2s\">Features</a><a href=\"#themes\" style=\"color:#555;text-decoration:none;transition:color 0.2s\">Themes</a><a href=\"#pricing\" style=\"color:#555;text-decoration:none;transition:color 0.2s\">Pricing</a></nav><a href=\"#demo\" style=\"background:#0a0a0a;color:#fff;padding:10px 24px;border-radius:50px;font-size:14px;font-weight:600;text-decoration:none;transition:background 0.2s, transform 0.1s\">Book Demo</a></header><main style=\"flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:100px 24px;position:relative;overflow:hidden\"><div style=\"position:absolute;top:50%;left:50%;transform:translate(-50%, -50%);width:700px;height:700px;background:radial-gradient(circle, rgba(212,175,55,0.15) 0%, transparent 70%);pointer-events:none;border-radius:50%\"></div><div style=\"display:inline-flex;align-items:center;gap:8px;background:rgba(212,175,55,0.12);border:1px solid rgba(212,175,55,0.3);border-radius:50px;padding:6px 18px;font-size:13px;font-weight:600;color:#8B6914;margin-bottom:28px;z-index:1\">✨ AI-Powered Photobooth Platform</div><h1 style=\"font-size:clamp(36px, 6vw, 72px);font-weight:800;line-height:1.1;letter-spacing:-0.03em;max-width:800px;color:#0a0a0a;margin:0 0 24px;z-index:1\">The Ultimate<!-- --> <span style=\"color:#D4AF37\">AI Photobooth</span> <!-- -->Experience.</h1><p style=\"font-size:clamp(16px, 2vw, 20px);color:#666;max-width:560px;line-height:1.7;margin:0 0 48px;font-weight:400;z-index:1\">Transform your events with world-class AI imaging. Instantly generate stunning, premium avatars for your guests.</p><div style=\"display:flex;gap:16px;flex-wrap:wrap;justify-content:center;z-index:1\"><a href=\"#start\" style=\"background:#D4AF37;color:#fff;padding:16px 40px;border-radius:50px;font-size:16px;font-weight:700;text-decoration:none;box-shadow:0 12px 40px rgba(212,175,55,0.35);transition:transform 0.15s, box-shadow 0.15s\">Get Started →</a><a href=\"#gallery\" style=\"background:#fff;color:#0a0a0a;padding:16px 40px;border-radius:50px;font-size:16px;font-weight:600;text-decoration:none;border:1px solid rgba(0,0,0,0.08);box-shadow:0 4px 16px rgba(0,0,0,0.06);transition:transform 0.15s\">View Gallery</a></div></main><section id=\"features\" style=\"padding:80px 40px;background:#f5f5f7\"><div style=\"max-width:1100px;margin:0 auto\"><h2 style=\"text-align:center;font-size:clamp(28px, 4vw, 48px);font-weight:800;letter-spacing:-0.02em;margin-bottom:16px;color:#0a0a0a\">Everything you need.</h2><p style=\"text-align:center;color:#666;font-size:18px;margin-bottom:60px\">Built for events of every scale — from intimate weddings to massive festivals.</p><div style=\"display:grid;grid-template-columns:repeat(auto-fit, minmax(260px, 1fr));gap:24px\"><div style=\"background:#fff;border-radius:24px;padding:32px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.04);transition:transform 0.2s, box-shadow 0.2s\"><div style=\"font-size:36px;margin-bottom:16px\">📸</div><h3 style=\"font-size:20px;font-weight:700;color:#0a0a0a;margin-bottom:8px\">Smart Camera</h3><p style=\"color:#777;line-height:1.6;font-size:15px;margin:0\">AI-powered face detection and smart framing for perfect shots every time.</p></div><div style=\"background:#fff;border-radius:24px;padding:32px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.04);transition:transform 0.2s, box-shadow 0.2s\"><div style=\"font-size:36px;margin-bottom:16px\">🎨</div><h3 style=\"font-size:20px;font-weight:700;color:#0a0a0a;margin-bottom:8px\">100+ AI Themes</h3><p style=\"color:#777;line-height:1.6;font-size:15px;margin:0\">From Anime to Luxury, Royal to Cyberpunk — themes for every event.</p></div><div style=\"background:#fff;border-radius:24px;padding:32px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.04);transition:transform 0.2s, box-shadow 0.2s\"><div style=\"font-size:36px;margin-bottom:16px\">⚡</div><h3 style=\"font-size:20px;font-weight:700;color:#0a0a0a;margin-bottom:8px\">Instant Generation</h3><p style=\"color:#777;line-height:1.6;font-size:15px;margin:0\">AI generates stunning portrait art in under 15 seconds.</p></div><div style=\"background:#fff;border-radius:24px;padding:32px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.04);transition:transform 0.2s, box-shadow 0.2s\"><div style=\"font-size:36px;margin-bottom:16px\">🖨️</div><h3 style=\"font-size:20px;font-weight:700;color:#0a0a0a;margin-bottom:8px\">Instant Print</h3><p style=\"color:#777;line-height:1.6;font-size:15px;margin:0\">Supports multiple printer brands with auto-queue management.</p></div><div style=\"background:#fff;border-radius:24px;padding:32px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.04);transition:transform 0.2s, box-shadow 0.2s\"><div style=\"font-size:36px;margin-bottom:16px\">📱</div><h3 style=\"font-size:20px;font-weight:700;color:#0a0a0a;margin-bottom:8px\">QR Download</h3><p style=\"color:#777;line-height:1.6;font-size:15px;margin:0\">Secure QR codes for easy sharing to Instagram, TikTok, and more.</p></div><div style=\"background:#fff;border-radius:24px;padding:32px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.04);transition:transform 0.2s, box-shadow 0.2s\"><div style=\"font-size:36px;margin-bottom:16px\">📊</div><h3 style=\"font-size:20px;font-weight:700;color:#0a0a0a;margin-bottom:8px\">Live Analytics</h3><p style=\"color:#777;line-height:1.6;font-size:15px;margin:0\">Real-time dashboard tracking visitors, prints, and AI performance.</p></div></div></div></section><section id=\"pricing\" style=\"padding:80px 40px;background:#fff\"><div style=\"max-width:1100px;margin:0 auto\"><h2 style=\"text-align:center;font-size:clamp(28px, 4vw, 48px);font-weight:800;letter-spacing:-0.02em;margin-bottom:16px;color:#0a0a0a\">Simple Pricing.</h2><p style=\"text-align:center;color:#666;font-size:18px;margin-bottom:60px\">No hidden fees. Pay for what you use.</p><div style=\"display:grid;grid-template-columns:repeat(auto-fit, minmax(240px, 1fr));gap:24px;align-items:start\"><div style=\"background:#fff;color:#0a0a0a;border-radius:24px;padding:36px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.04);transform:scale(1)\"><h3 style=\"font-size:24px;font-weight:800;margin:0 0 4px\">Starter</h3><div style=\"font-size:20px;font-weight:700;color:#D4AF37;margin:8px 0\">Pay/Event</div><p style=\"font-size:14px;color:#888;margin-bottom:24px\">Perfect for freelancers &amp; small events</p><ul style=\"list-style:none;padding:0;margin:0 0 32px\"><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->500 images/event</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->3 AI themes</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->QR downloads</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->Basic analytics</li></ul><a href=\"#demo\" style=\"display:block;text-align:center;background:#0a0a0a;color:#fff;padding:14px 24px;border-radius:50px;font-weight:700;font-size:15px;text-decoration:none\">Get Started</a></div><div style=\"background:#0a0a0a;color:#fff;border-radius:24px;padding:36px;border:2px solid #D4AF37;box-shadow:0 20px 60px rgba(0,0,0,0.2);transform:scale(1.04)\"><div style=\"background:#D4AF37;color:#fff;border-radius:50px;padding:4px 14px;font-size:12px;font-weight:700;display:inline-block;margin-bottom:16px\">MOST POPULAR</div><h3 style=\"font-size:24px;font-weight:800;margin:0 0 4px\">Professional</h3><div style=\"font-size:20px;font-weight:700;color:#D4AF37;margin:8px 0\">Custom/Month</div><p style=\"font-size:14px;color:#aaa;margin-bottom:24px\">For agencies &amp; active organizers</p><ul style=\"list-style:none;padding:0;margin:0 0 32px\"><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->Unlimited events</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->All premium themes</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->White-label (no watermark)</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->Priority AI queue</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->Full analytics</li></ul><a href=\"#demo\" style=\"display:block;text-align:center;background:#D4AF37;color:#fff;padding:14px 24px;border-radius:50px;font-weight:700;font-size:15px;text-decoration:none\">Get Started</a></div><div style=\"background:#fff;color:#0a0a0a;border-radius:24px;padding:36px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.04);transform:scale(1)\"><h3 style=\"font-size:24px;font-weight:800;margin:0 0 4px\">Enterprise</h3><div style=\"font-size:20px;font-weight:700;color:#D4AF37;margin:8px 0\">Contact Us</div><p style=\"font-size:14px;color:#888;margin-bottom:24px\">For brands, malls &amp; large venues</p><ul style=\"list-style:none;padding:0;margin:0 0 32px\"><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->Unlimited everything</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->Custom AI model</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->Dedicated server</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->API access</li><li style=\"font-size:14px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;gap:8px\"><span style=\"color:#D4AF37\">✓</span> <!-- -->24/7 support</li></ul><a href=\"#demo\" style=\"display:block;text-align:center;background:#0a0a0a;color:#fff;padding:14px 24px;border-radius:50px;font-weight:700;font-size:15px;text-decoration:none\">Contact Sales</a></div></div></div></section><footer style=\"padding:40px;text-align:center;font-size:14px;color:#999;border-top:1px solid rgba(0,0,0,0.08);background:#f5f5f7\">© <!-- -->2026<!-- --> AI SNAP Platform · Built for world-class events</footer></div><!--$--><!--/$--><script src=\"/_next/static/chunks/1_akdfhhqaauv.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/158myu8e_yme3.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chun